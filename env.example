# ---- Server ----
PORT=8080
NODE_ENV=production
JWT_SECRET=change_me_to_a_long_random_string
APP_HASHCODE=861317
CLIENT_ORIGIN=https://your-frontend.up.railway.app

# ---- Database (Railway injects DATABASE_URL automatically when you add a Postgres plugin) ----
DATABASE_URL=postgres://user:password@host:5432/railway

# ---- Which Salesforce org this deployment uses ----
# Set SF_LOCKED_ORG to 'production' or 'sandbox' when running Production and Sandbox
# as two separate, parallel Railway services (recommended — see README). This pins the
# org permanently for this deployment and disables the Admin UI's "Set as Active" toggle,
# so the two deployments can never accidentally cross-talk to the wrong org.
# Leave it unset if you're running a single deployment that toggles orgs from the Admin UI.
SF_LOCKED_ORG=production
SF_DEFAULT_ORG=sandbox

# ---- Anthropic (Ask AI) — can also be set from Admin > Claude / Ask AI Settings ----
ANTHROPIC_API_KEY=

# ---- Cookie/session ----
OTP_EXPIRY_MINUTES=10
SESSION_EXPIRY_HOURS=12
